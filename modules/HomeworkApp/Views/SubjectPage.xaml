<Page x:Class="HomeworkApp.Views.SubjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <Button x:Name="BtnBack"
                    Content="← 返回"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="BtnBack_Click"/>

            <TextBlock Text="选择学科"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="选择作业所属学科，然后导入作业文件"
                       Style="{StaticResource PageSubtitleStyle}"
                       Margin="0,0,0,30"/>
        </StackPanel>

        <!-- Subject Buttons -->
        <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}" VerticalAlignment="Center">
        <UniformGrid Rows="1" Columns="3" HorizontalAlignment="Center">
            <Button x:Name="BtnChinese"
                    Content="语文"
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="18"
                    Padding="40,30"
                    Margin="10"
                    Click="BtnChinese_Click"/>

            <Button x:Name="BtnMath"
                    Content="数学"
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="18"
                    Padding="40,30"
                    Margin="10"
                    Click="BtnMath_Click"/>

            <Button x:Name="BtnEnglish"
                    Content="英语"
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="18"
                    Padding="40,30"
                    Margin="10"
                    Click="BtnEnglish_Click"/>
        </UniformGrid>
        </Border>
    </Grid>
</Page>
