<Page x:Class="HomeworkApp.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="作业模块"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,10"/>
            <TextBlock Text="整理作业、继续批注，或者直接进入历史记录。"
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Quick Actions -->
        <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Button x:Name="BtnNewHomework"
                        Content="+ 新建作业"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="18"
                        Padding="40,20"
                        Margin="0,0,0,12"
                        Click="BtnNewHomework_Click"/>

                <Button x:Name="BtnContinueHomework"
                        Content="继续上次作业"
                        Style="{StaticResource SecondaryButtonStyle}"
                        FontSize="16"
                        Padding="30,15"
                        Margin="0,0,0,18"
                        Click="BtnContinueHomework_Click"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnHistory"
                            Grid.Column="0"
                            Content="历史作业"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="22,10"
                            HorizontalAlignment="Left"
                            Click="BtnHistory_Click"/>

                    <Button x:Name="BtnSettings"
                            Grid.Column="1"
                            Content="设置"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="22,10"
                            HorizontalAlignment="Right"
                            Click="BtnSettings_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
