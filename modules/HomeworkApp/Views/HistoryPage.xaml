<Page x:Class="HomeworkApp.Views.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button x:Name="BtnBack"
                    Content="← 返回"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="BtnBack_Click"/>

            <TextBlock Text="历史作业"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="继续打开之前的作业，或者直接删除。"
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Job List -->
        <Border Grid.Row="1"
                Style="{StaticResource PanelCardStyle}">

            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LstJobs">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="15"
                                        Margin="0,5"
                                        Background="{StaticResource CardBackground}"
                                        CornerRadius="12"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Subject}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       Margin="0,0,0,5"/>

                                            <TextBlock FontSize="12" Foreground="{StaticResource MutedText}">
                                                <Run Text="页数："/>
                                                <Run Text="{Binding TotalPages}"/>
                                                <Run Text="  |  "/>
                                                <Run Text="创建时间："/>
                                                <Run Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                                <Run Text="  |  "/>
                                                <Run Text="更新时间："/>
                                                <Run Text="{Binding UpdateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                            </TextBlock>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border Background="#2A2A2A" CornerRadius="6" Padding="6,2" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding DocumentType}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedText}"/>
                                                </Border>

                                                <Border x:Name="PrintedBorder"
                                                        Background="#1A3A2A"
                                                        CornerRadius="6"
                                                        Padding="6,2"
                                                        Visibility="Collapsed">
                                                    <TextBlock Text="已打印"
                                                               FontSize="11"
                                                               Foreground="{StaticResource Accent}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="继续"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="20,8"
                                                Margin="10,0"
                                                Tag="{Binding JobId}"
                                                Click="BtnContinue_Click"/>

                                        <Button Grid.Column="2"
                                                Content="删除"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="15,8"
                                                Tag="{Binding JobId}"
                                                Click="BtnDelete_Click"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPrinted}" Value="True">
                                        <Setter TargetName="PrintedBorder" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border x:Name="EmptyState" Visibility="Collapsed" Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="暂无历史作业" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="做过的作业会显示在这里。" Style="{StaticResource PageSubtitleStyle}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
