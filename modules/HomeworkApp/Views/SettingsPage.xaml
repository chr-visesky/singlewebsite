<Page x:Class="HomeworkApp.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button x:Name="BtnBack"
                    Content="← 返回"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="BtnBack_Click"/>

            <TextBlock Text="设置"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Settings Content -->
        <StackPanel Grid.Row="1" MaxWidth="600">
            <!-- Printer Settings -->
            <Border
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,0,15"
                    >

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="打印机设置"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="默认打印机"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   Margin="0,0,0,8"/>

                        <ComboBox x:Name="CmbPrinters"
                                  FontSize="14"
                                  Padding="10"
                                  Background="{StaticResource CardBackground}"
                                  Foreground="{StaticResource PrimaryText}"
                                  SelectionChanged="CmbPrinters_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="纸张大小："
                                   FontSize="14"
                                   Foreground="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <ComboBox x:Name="CmbPaperSize"
                                  FontSize="14"
                                  Padding="8,4"
                                  Background="{StaticResource CardBackground}"
                                  Foreground="{StaticResource PrimaryText}"
                                  SelectionChanged="CmbPaperSize_SelectionChanged">
                            <ComboBoxItem Content="A4" IsSelected="True"/>
                            <ComboBoxItem Content="A3"/>
                            <ComboBoxItem Content="Letter"/>
                            <ComboBoxItem Content="B5"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Data Settings -->
            <Border
                    Style="{StaticResource PanelCardStyle}"
                    Margin="0,0,0,15"
                    >

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="数据存储"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1">
                        <TextBlock FontSize="14" Foreground="{StaticResource MutedText}" Margin="0,0,0,10">
                            <Run Text="作业数据存储在："/>
                            <Run x:Name="TxtStoragePath" FontWeight="SemiBold"/>
                        </TextBlock>

                        <Button x:Name="BtnOpenStorage"
                                Content="打开存储文件夹"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="15,8"
                                HorizontalAlignment="Left"
                                Click="BtnOpenStorage_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource PanelCardStyle}">

                <StackPanel>
                    <TextBlock Text="关于"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,10"/>

                    <TextBlock FontSize="14" Foreground="{StaticResource MutedText}">
                        <Run Text="StudyGate 作业模块 v1.0"/>
                        <LineBreak/>
                        <Run Text="用于整理、批注和打印作业。"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
