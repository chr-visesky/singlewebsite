<Page x:Class="HomeworkApp.Views.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:infc="clr-namespace:System.Windows.Ink;assembly=PresentationCore"
      Background="Transparent">

    <Page.Resources>
        <!-- Thin Horizontal Scrollbar Style -->
    </Page.Resources>

    <Grid Margin="12">
        <!-- Main Content: Homework, Draft, Right Panel -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="400"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="LeftColumn" Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Homework Area (A4 fixed size) -->
        <Grid x:Name="HomeworkHost" Grid.Column="0" Background="Transparent">
            <ScrollViewer x:Name="HomeworkScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                          SizeChanged="HomeworkGrid_SizeChanged">
                <Viewbox x:Name="HomeworkViewbox" Stretch="Uniform" StretchDirection="Both">
                    <Grid x:Name="HomeworkContainer" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <!-- A4 Paper Background -->
                        <Border x:Name="A4Background" Width="794" Height="1123"
                                Background="White" BorderBrush="#CCCCCC" BorderThickness="1"/>
                        <!-- Document Image -->
                        <Image x:Name="DocumentImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="Collapsed" ClipToBounds="True"
                               Width="794" Height="1123"/>
                        <!-- Ink Canvas for handwriting -->
                        <InkCanvas x:Name="MainInkCanvas" Background="Transparent"
                                   EditingMode="Ink" UseCustomCursor="True"/>
                    </Grid>
                </Viewbox>
            </ScrollViewer>
        </Grid>

        <!-- Right: Draft Area (fills remaining space, height matches homework) -->
        <Grid x:Name="DraftHost" Grid.Column="1" Margin="12,0,0,0" Background="Transparent" SizeChanged="DraftGrid_SizeChanged">
            <ScrollViewer x:Name="DraftScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="DraftScrollViewer_PreviewMouseWheel">
                <Grid x:Name="DraftContainer" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <!-- Draft Paper Background -->
                    <Border x:Name="DraftA4Background" Width="794" Height="1123"
                            Background="White" BorderBrush="#CCCCCC" BorderThickness="1"/>
                    <!-- Ink Canvas for handwriting -->
                    <InkCanvas x:Name="DraftInkCanvas" Background="Transparent"
                               EditingMode="Ink" UseCustomCursor="True"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Floating Tool Button - Bottom Right -->
        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,15,15" Background="Transparent">
            <Border CornerRadius="30" Padding="8" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Button x:Name="BtnTools" Content="✏" Style="{StaticResource SecondaryButtonStyle}"
                        Width="50" Height="50" FontSize="22" Padding="0"
                        Click="BtnTools_Click" ToolTip="工具"/>
            </Border>
        </Border>

        <!-- Collapsible Tool Panel -->
        <Border x:Name="ToolPanel" Grid.ColumnSpan="2" VerticalAlignment="Center"
                HorizontalAlignment="Right" Margin="0,0,15,80" Visibility="Collapsed"
                Background="Transparent">
            <Border CornerRadius="12" Padding="8" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <!-- Pen/Eraser -->
                    <Button x:Name="BtnPen" Content="✏" Style="{StaticResource SecondaryButtonStyle}"
                            Width="40" Height="40" FontSize="18" Padding="0" Margin="0,0,0,4"
                            Click="BtnPen_Click" ToolTip="笔"/>
                    <Button x:Name="BtnEraser" Content="⌫" Style="{StaticResource SecondaryButtonStyle}"
                            Width="40" Height="40" FontSize="18" Padding="0" Margin="0,0,0,8"
                            Click="BtnEraser_Click" ToolTip="橡皮"/>

                    <!-- Colors -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorBlack" Width="24" Height="24" Background="Black"
                                CornerRadius="12" BorderBrush="#69D8C2" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="黑色">
                            <Border.Tag>Black</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorRed" Width="24" Height="24" Background="Red"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="红色">
                            <Border.Tag>Red</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorBlue" Width="24" Height="24" Background="Blue"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="蓝色">
                            <Border.Tag>Blue</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorGreen" Width="24" Height="24" Background="Green"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="绿色">
                            <Border.Tag>Green</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Border x:Name="ColorYellow" Width="24" Height="24" Background="Yellow"
                                CornerRadius="12" BorderBrush="#CCCCCC" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="黄色">
                            <Border.Tag>Yellow</Border.Tag>
                        </Border>
                    </StackPanel>

                    <!-- Pen Width -->
                    <Border Width="32" Height="4" Background="#69D8C2" CornerRadius="2"
                            Cursor="Hand" MouseLeftButtonDown="Width1_Click"
                            Margin="0,0,0,3" ToolTip="细"/>
                    <Border Width="32" Height="7" Background="#D6C7B3" CornerRadius="3"
                            Cursor="Hand" MouseLeftButtonDown="Width2_Click"
                            Margin="0,0,0,3" ToolTip="中"/>
                    <Border Width="32" Height="11" Background="#F8F2E9" CornerRadius="5"
                            Cursor="Hand" MouseLeftButtonDown="Width3_Click"
                            Margin="0,0,0,8" ToolTip="粗"/>

                    <!-- Zoom -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="-" Width="28" Height="28"
                                Style="{StaticResource SecondaryButtonStyle}" FontSize="14"
                                Padding="0" Click="ZoomOut_Click"/>
                        <Button Content="+" Width="28" Height="28"
                                Style="{StaticResource SecondaryButtonStyle}" FontSize="14"
                                Padding="0" Margin="4,0,0,0" Click="ZoomIn_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtZoom" Text="100%" FontSize="10"
                               Foreground="{StaticResource MutedText}" HorizontalAlignment="Center"
                               Margin="0,4,0,8"/>

                    <!-- Clear -->
                    <Button x:Name="BtnClearPage" Content="🗑" Style="{StaticResource SecondaryButtonStyle}"
                            Width="40" Height="40" FontSize="16" Padding="0"
                            Click="BtnClearPage_Click" ToolTip="清空本页"/>
                    <Button x:Name="BtnClearDraft" Content="🗑" Style="{StaticResource SecondaryButtonStyle}"
                            Width="40" Height="40" FontSize="16" Padding="0" Margin="0,4,0,8"
                            Click="BtnClearDraft_Click" ToolTip="清空草稿"/>

                    <!-- Page Ratio -->
                    <Button x:Name="BtnPageRatio" Content="A4 竖" Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="10" Padding="8,4" Margin="0,8,0,0" Click="BtnPageRatio_Click"/>

                    <!-- Print -->
                    <Button x:Name="BtnPrint" Content="🖨 打印" Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="10" Padding="10,4" Margin="0,4,0,0" Click="BtnPrint_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Expand/Collapse button - positioned at top right, toggles right panel -->
        <Button x:Name="BtnExpandLeft" Grid.Column="1" Content="▶"
                FontSize="16" Padding="4,2"
                Click="BtnExpandLeft_Click" ToolTip="展开/收缩右侧"
                Visibility="Visible" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,5,0"
                Panel.ZIndex="1000" Background="Transparent" Foreground="{StaticResource MutedText}"
                BorderThickness="0" Cursor="Hand"/>

        <!-- Right: Homework Assistant Tree (collapsible) -->
        <Border x:Name="LeftPanel" Grid.Column="2" Margin="12,0,0,0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="作业助手" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}"/>
                            <TextBlock x:Name="TxtToday" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Page Navigation -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="BtnPrevPage" Content="◀" Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnPrevPage_Click" Padding="6,4" FontSize="11"/>
                        <TextBlock x:Name="TxtPageInfo" Text="1/5" FontSize="11" Foreground="{StaticResource MutedText}"
                                   VerticalAlignment="Center" MinWidth="50" TextAlignment="Center" Margin="4,0"/>
                        <Button x:Name="BtnNextPage" Content="▶" Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnNextPage_Click" Padding="6,4" FontSize="11"/>
                    </StackPanel>

                    <!-- Menu Button -->
                    <Button x:Name="BtnMenu" Content="☰ 菜单" Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="11" Padding="8,4" Margin="0,6,0,0" Click="BtnMenu_Click"/>
                </StackPanel>

                <!-- Tree View -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <TreeView x:Name="HomeworkTree" Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource PrimaryText}" FontSize="13">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border Name="Bd" Padding="4,2" CornerRadius="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton Name="Expander" Grid.Column="0"
                                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                    ClickMode="Press"
                                                                    Foreground="{StaticResource PrimaryText}">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Path Name="Arrow" Width="6" Height="10"
                                                                                      Data="M0,0 L6,5 L0,10 Z"
                                                                                      Fill="{StaticResource MutedText}"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                            <Setter.Value>
                                                                                                <RotateTransform Angle="90" CenterX="3" CenterY="5"/>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <ContentPresenter Name="Header" Grid.Column="1"
                                                                        ContentSource="Header"/>
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter Name="ItemsPresenter" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A2A35"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#20303B"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
