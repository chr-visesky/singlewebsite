<Page x:Class="HomeworkApp.Views.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:infc="clr-namespace:System.Windows.Ink;assembly=PresentationCore"
      Background="Transparent"
       AllowDrop="True"
       PreviewKeyDown="EditorPage_PreviewKeyDown"
       DragOver="Page_DragOver"
      Drop="Page_Drop">

    <Page.Resources>
        <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsTabStop="False"
                                                  Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        CornerRadius="0"
                                                        Background="#6E6E6E"
                                                        BorderThickness="0"
                                                        MinWidth="1"
                                                        MinHeight="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#000000"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#000000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsTabStop="False"
                                                  Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="1"/>
                                <Setter Property="Width" Value="Auto"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="1"/>
                                <Setter Property="Height" Value="Auto"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <DropShadowEffect x:Key="PaperShadowEffect"
                          BlurRadius="0"
                          ShadowDepth="0"
                          Opacity="0"
                          Color="#000000"/>

        <Style x:Key="PaperSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DFDDD8"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Effect" Value="{StaticResource PaperShadowEffect}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="EditorLayoutRoot" Margin="6" Background="#E6E3DD">
        <!-- Main Content: Assistant, Thumbnails, Homework, Draft -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="200"/>
            <ColumnDefinition x:Name="ThumbnailColumn" Width="72"/>
            <ColumnDefinition Width="2*" MinWidth="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Assistant -->
        <Border x:Name="LeftPanel" Grid.Column="0" Margin="0,0,0,0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="作业助手" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}"/>
                            <TextBlock x:Name="TxtToday" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Menu Button -->
                    <Button x:Name="BtnMenu" AutomationProperties.AutomationId="BtnMenu" Content="☰ 菜单" Style="{StaticResource AssistantRectButtonStyle}"
                            FontSize="11" Padding="8,4" Margin="0,6,0,0" Click="BtnMenu_Click"/>
                </StackPanel>

                <!-- Tree View -->
                <ScrollViewer x:Name="HomeworkTreeScrollViewer"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="HomeworkTreeScrollViewer_PreviewMouseWheel">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <TreeView x:Name="HomeworkTree" Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Foreground="{StaticResource PrimaryText}" FontSize="13">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border Name="Bd" Padding="4,2" CornerRadius="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton Name="Expander" Grid.Column="0"
                                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                    ClickMode="Press"
                                                                    Foreground="{StaticResource PrimaryText}">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Path Name="Arrow" Width="6" Height="10"
                                                                                      Data="M0,0 L6,5 L0,10 Z"
                                                                                      Fill="{StaticResource MutedText}"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                            <Setter.Value>
                                                                                                <RotateTransform Angle="90" CenterX="3" CenterY="5"/>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <TextBlock Name="HeaderText"
                                                                   Grid.Column="1"
                                                                   Text="{TemplateBinding Header}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{TemplateBinding Foreground}"/>
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter Name="ItemsPresenter" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                </Trigger>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsPresenter" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="HeaderText" Property="Foreground" Value="#4A90E2"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsSelectionActive" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="HeaderText" Property="Foreground" Value="#4A90E2"/>
                                                </MultiTrigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource MutedText}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button x:Name="BtnExpandLeft"
                AutomationProperties.AutomationId="BtnExpandLeft"
                Grid.Column="1"
                Content="◀"
                Click="BtnExpandLeft_Click"
                Visibility="Visible"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="-6,0,0,0"
                Width="10"
                Height="44"
                Panel.ZIndex="1000"
                Background="{StaticResource PanelBackground}"
                Foreground="{StaticResource MutedText}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                FontSize="14"
                Padding="0"
                Cursor="Hand"
                ToolTip="收起作业助手"/>

        <Border x:Name="ThumbnailHost"
                Grid.Column="1"
                Width="72"
                Margin="1,0,1,0"
                Background="#66E6E3DD"
                Visibility="Visible">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <StackPanel x:Name="ThumbnailPanel" Margin="6,6,6,6"/>
            </ScrollViewer>
        </Border>

        <!-- Homework Area (A4 fixed size) -->
        <Grid x:Name="HomeworkHost" Grid.Column="2" Background="Transparent">
            <ScrollViewer x:Name="HomeworkScrollViewer"
                          AutomationProperties.AutomationId="HomeworkScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          CanContentScroll="False"
                          PreviewMouseLeftButtonDown="ScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="ScrollViewer_PreviewMouseLeftButtonUp"
                          PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                          ScrollChanged="HomeworkScrollViewer_ScrollChanged"
                          SizeChanged="HomeworkGrid_SizeChanged">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <Grid x:Name="HomeworkContainer" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0,0">
                    <!-- A4 Paper Background -->
                    <Border x:Name="A4Background" Width="794" Height="1123"
                            Style="{StaticResource PaperSurfaceStyle}"/>
                    <!-- Document Image -->
                    <Image x:Name="DocumentImage" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="Collapsed" ClipToBounds="True"
                           Width="794" Height="1123"/>
                    <!-- Ink Canvas for handwriting -->
                    <InkCanvas x:Name="MainInkCanvas" AutomationProperties.AutomationId="MainInkCanvas" Background="Transparent"
                               EditingMode="Ink" UseCustomCursor="True"/>
                </Grid>
            </ScrollViewer>
            <Border x:Name="HomeworkScrollIndicator"
                    Width="1"
                    Background="#6E6E6E"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"/>
        </Grid>

        <!-- Draft Area (fills remaining space, height matches homework) -->
        <Grid x:Name="DraftHost" Grid.Column="3" Margin="1,0,0,0" Background="Transparent" SizeChanged="DraftGrid_SizeChanged">
            <ScrollViewer x:Name="DraftScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          CanContentScroll="False"
                          PreviewMouseLeftButtonDown="ScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="ScrollViewer_PreviewMouseLeftButtonUp"
                          PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                          PreviewMouseWheel="DraftScrollViewer_PreviewMouseWheel"
                          ScrollChanged="DraftScrollViewer_ScrollChanged">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <Grid x:Name="DraftContainer" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <!-- Draft Paper Background -->
                    <Border x:Name="DraftA4Background" Width="794" Height="1123"
                            Style="{StaticResource PaperSurfaceStyle}"/>
                    <!-- Ink Canvas for handwriting -->
                    <InkCanvas x:Name="DraftInkCanvas" Background="Transparent"
                               EditingMode="Ink" UseCustomCursor="True"/>
                </Grid>
            </ScrollViewer>
            <Border x:Name="DraftScrollIndicator"
                    Width="1"
                    Background="#6E6E6E"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"/>
        </Grid>

        <StackPanel Grid.ColumnSpan="4"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,10,10"
                    Background="Transparent"
                    Panel.ZIndex="2000">
            <!-- Collapsible Tool Panel -->
            <Border x:Name="ToolPanel"
                    Visibility="Collapsed"
                    Background="Transparent">
                <Border CornerRadius="10,10,0,0" Padding="6" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                    <!-- Pen/Eraser -->
                    <Button x:Name="BtnPen" Content="✏" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="14" Padding="0" Margin="0,0,0,4"
                            Click="BtnPen_Click" ToolTip="笔"/>
                    <Button x:Name="BtnSelect" Content="⬚" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="12" Padding="0" Margin="0,0,0,4"
                            Click="BtnSelect_Click" ToolTip="选中字迹"/>
                    <Button x:Name="BtnHand" Content="✋" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="12" Padding="0" Margin="0,0,0,4"
                            Click="BtnHand_Click" ToolTip="拖动画布"/>
                    <Button x:Name="BtnEraser" Content="⌫" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="14" Padding="0" Margin="0,0,0,8"
                            Click="BtnEraser_Click" ToolTip="橡皮"/>

                    <!-- Colors -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorBlack" Width="24" Height="24" Background="Black"
                                CornerRadius="12" BorderBrush="#69D8C2" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="黑色">
                            <Border.Tag>Black</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorRed" Width="24" Height="24" Background="Red"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="红色">
                            <Border.Tag>Red</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorBlue" Width="24" Height="24" Background="Blue"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="蓝色">
                            <Border.Tag>Blue</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border x:Name="ColorGreen" Width="24" Height="24" Background="Green"
                                CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="绿色">
                            <Border.Tag>Green</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Border x:Name="ColorYellow" Width="24" Height="24" Background="Yellow"
                                CornerRadius="12" BorderBrush="#CCCCCC" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonDown="Color_Click" ToolTip="黄色">
                            <Border.Tag>Yellow</Border.Tag>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Button AutomationProperties.AutomationId="ColorGray"
                                Width="24" Height="24" Padding="0" BorderThickness="0"
                                Background="Transparent" Cursor="Hand" Click="ColorButton_Click" ToolTip="灰色">
                            <Button.Tag>Gray</Button.Tag>
                            <Border x:Name="ColorGray" Width="24" Height="24" Background="#808080"
                                    CornerRadius="12" BorderBrush="Transparent" BorderThickness="2"/>
                        </Button>
                    </StackPanel>

                    <!-- Pen Width -->
                    <Border x:Name="WidthBarThin" Width="32" Height="1" Background="#000000" CornerRadius="0"
                            Cursor="Hand" MouseLeftButtonDown="Width1_Click"
                            Margin="0,0,0,5" ToolTip="1px"/>
                    <Border x:Name="WidthBarMedium" Width="32" Height="3" Background="#000000" CornerRadius="0"
                            Cursor="Hand" MouseLeftButtonDown="Width2_Click"
                            Margin="0,0,0,5" ToolTip="3px"/>
                    <Border x:Name="WidthBarBold" Width="32" Height="6" Background="#000000" CornerRadius="0"
                            Cursor="Hand" MouseLeftButtonDown="Width3_Click"
                            Margin="0,0,0,8" ToolTip="6px"/>

                    <!-- Zoom -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnZoomOut" AutomationProperties.AutomationId="BtnZoomOut" Content="-" Width="24" Height="24"
                                Style="{StaticResource SecondaryButtonStyle}" FontSize="12"
                                Padding="0" Click="ZoomOut_Click"/>
                        <Button x:Name="BtnZoomIn" AutomationProperties.AutomationId="BtnZoomIn" Content="+" Width="24" Height="24"
                                Style="{StaticResource SecondaryButtonStyle}" FontSize="12"
                                Padding="0" Margin="4,0,0,0" Click="ZoomIn_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtZoom" AutomationProperties.AutomationId="TxtZoom" Text="100%" FontSize="10"
                               Foreground="{StaticResource MutedText}" HorizontalAlignment="Center"
                               Margin="0,4,0,8"/>

                    <!-- Clear -->
                    <Button x:Name="BtnClearPage" Content="🗑" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="12" Padding="0"
                            Click="BtnClearPage_Click" ToolTip="清空本页"/>
                    <Button x:Name="BtnClearDraft" Content="🗑" Style="{StaticResource SecondaryButtonStyle}"
                            Width="32" Height="32" FontSize="12" Padding="0" Margin="0,4,0,8"
                            Click="BtnClearDraft_Click" ToolTip="清空草稿"/>

                    <!-- Page Ratio -->
                    <Button x:Name="BtnPageRatio" AutomationProperties.AutomationId="BtnPageRatio" Content="A4 竖" Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="9" Padding="6,3" Margin="0,8,0,0" Click="BtnPageRatio_Click"/>

                    <!-- Print -->
                    <Button x:Name="BtnPrint" AutomationProperties.AutomationId="BtnPrint" Content="🖨 打印" Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="9" Padding="8,3" Margin="0,4,0,0" Click="BtnPrint_Click"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Floating Tool Button - Bottom Right -->
            <Border Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="6"
                    Margin="0,-1,0,0">
                <Button x:Name="BtnTools" AutomationProperties.AutomationId="BtnTools" Content="✏" Style="{StaticResource SecondaryButtonStyle}"
                        Width="40" Height="40" FontSize="18" Padding="0"
                        Click="BtnTools_Click" ToolTip="工具"/>
            </Border>
        </StackPanel>

    </Grid>
</Page>
