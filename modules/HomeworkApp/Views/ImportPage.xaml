<Page x:Class="HomeworkApp.Views.ImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      AllowDrop="True"
      Drop="Page_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <Button x:Name="BtnBack"
                    Content="← 返回"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="BtnBack_Click"/>

            <TextBlock x:Name="TxtSubject"
                       Text="语文 - 导入作业"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="拖拽作业文件到下方区域，或点击按钮选择文件"
                       Style="{StaticResource PageSubtitleStyle}"
                       Margin="0,0,0,20"/>
        </StackPanel>

        <!-- Drop Zone -->
        <Border Grid.Row="1"
                x:Name="DropZone"
                BorderBrush="#69D8C2"
                BorderThickness="2"
                CornerRadius="16"
                Background="{StaticResource PanelBackground}"
                MouseLeftButtonDown="DropZone_MouseLeftButtonDown">

            <Grid Height="300">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📁"
                               FontSize="64"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="拖拽 PDF 或图片到此处"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource PrimaryText}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="支持单个 PDF，或多张图片"
                               FontSize="14"
                               Foreground="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Button x:Name="BtnSelectFile"
                            Content="选择文件"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="30,12"
                            Click="BtnSelectFile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- File List -->
        <Border x:Name="FileListPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="{StaticResource PanelBackground}"
                CornerRadius="16"
                Padding="20"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="TxtFiles"
                           Text="已选择 0 个文件"
                           FontSize="16"
                           Foreground="{StaticResource PrimaryText}"
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <ItemsControl x:Name="LstFiles">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,5" Background="{StaticResource CardBackground}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FullPath}"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedText}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="删除"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="10,5"
                                                Tag="{Binding FullPath}"
                                                Click="BtnRemoveFile_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2"
                        x:Name="BtnStartHomework"
                        Content="开始做作业"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="16"
                        Padding="40,15"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Right"
                        Click="BtnStartHomework_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
