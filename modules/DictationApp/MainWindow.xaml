<Window x:Class="DictationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudyGate 听写模块"
        AutomationProperties.AutomationId="DictationMainWindow"
        Icon="pack://application:,,,/Assets/module-icon.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Background="{StaticResource ModuleShellBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="392" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="20"
                Padding="20"
                Style="{StaticResource PanelBorderStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="听写任务"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="SidebarMetaTextBlock"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="左侧按分组管理任务，右侧直接编辑待听写词组。" />
                        </StackPanel>

                        <Button x:Name="CreateButton"
                                Grid.Column="1"
                                Width="44"
                                Height="44"
                                Margin="16,0,0,0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontFamily="Segoe UI"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Click="CreateButton_OnClick"
                                Content="+"
                                AutomationProperties.AutomationId="DictationCreateTaskButton"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </StackPanel>

                <ScrollViewer Margin="0,18,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TaskGroupsItemsControl"
                                  AutomationProperties.AutomationId="DictationTaskList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,2"
                                                Background="{StaticResource ModuleAccentSoftBrush}"
                                                CornerRadius="999">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ModuleAccentTextBrush}"
                                                       Text="{Binding Tasks.Count}" />
                                        </Border>
                                    </DockPanel>

                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="TaskCard"
                                                        Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="{StaticResource ModuleCardBackgroundBrush}"
                                                        BorderBrush="{StaticResource ModuleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="16"
                                                        MouseLeftButtonUp="TaskCard_OnMouseLeftButtonUp"
                                                        Tag="{Binding TaskId}"
                                                        Cursor="Hand">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <StackPanel>
                                                            <TextBlock FontSize="18"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Title}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Style="{StaticResource SectionBodyStyle}"
                                                                       Text="{Binding Summary}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1"
                                                                    Margin="0,12,0,0"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right">
                                                            <Button MinWidth="74"
                                                                    Margin="0,0,8,0"
                                                                    Padding="12,8"
                                                                    Click="TaskCardEditButton_OnClick"
                                                                    Content="编辑"
                                                                    Tag="{Binding TaskId}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                            <Button MinWidth="74"
                                                                    Padding="12,8"
                                                                    Click="TaskCardDeleteButton_OnClick"
                                                                    Content="删除"
                                                                    Tag="{Binding TaskId}"
                                                                    AutomationProperties.AutomationId="{Binding DeleteAutomationId}"
                                                                    Style="{StaticResource DangerButtonStyle}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="TaskCard" Property="Background" Value="{StaticResource ModuleAccentSoftBrush}" />
                                                        <Setter TargetName="TaskCard" Property="BorderBrush" Value="{StaticResource ModuleAccentBrush}" />
                                                        <Setter TargetName="TaskCard" Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,20,20,20"
                Padding="28"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="EditorModeTextBlock"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Text="新建词组" />
                        <TextBlock x:Name="EditorMetaTextBlock"
                                   Margin="0,10,0,0"
                                   FontSize="16"
                                   Foreground="{StaticResource ModuleMutedTextBrush}"
                                   Text="右侧直接逐条编辑待听写词组。" />
                    </StackPanel>

                        <Button x:Name="SettingsButton"
                            DockPanel.Dock="Right"
                            MinWidth="110"
                            Padding="14,10"
                            Click="SettingsButton_OnClick"
                            Content="朗读设置"
                            AutomationProperties.AutomationId="DictationSessionSettingsButton"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </DockPanel>

                <TextBlock x:Name="EditorStatusTextBlock"
                           Grid.Row="1"
                           Margin="0,14,0,0"
                           Style="{StaticResource SectionBodyStyle}"
                           Text="左侧选中任务后，右侧直接编辑并保存。" />

                <Border Grid.Row="2"
                        Margin="0,20,0,0"
                        Padding="20"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="词组标题"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <TextBox x:Name="TaskTitleTextBox"
                                         Margin="0,8,0,0"
                                         Height="38"
                                         AutomationProperties.AutomationId="DictationTaskTitleTextBox"
                                         TextChanged="EditorValue_OnChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="分组 / 课次"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <TextBox x:Name="LessonTitleTextBox"
                                         Margin="0,8,0,0"
                                         Height="38"
                                         AutomationProperties.AutomationId="DictationLessonTitleTextBox"
                                         TextChanged="EditorValue_OnChanged" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="科目"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <ComboBox x:Name="SubjectComboBox"
                                          Margin="0,8,0,0"
                                          SelectionChanged="EditorValue_OnChanged">
                                    <ComboBoxItem Content="语文" />
                                    <ComboBoxItem Content="英语" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,12,0">
                                <TextBlock Text="课内 / 课外"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <ComboBox x:Name="BucketComboBox"
                                          Margin="0,8,0,0"
                                          SelectionChanged="EditorValue_OnChanged">
                                    <ComboBoxItem Content="课内" />
                                    <ComboBoxItem Content="课外" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="0,0,12,0">
                                <TextBlock Text="朗读语言"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <ComboBox x:Name="LanguageComboBox"
                                          Margin="0,8,0,0"
                                          SelectionChanged="EditorValue_OnChanged">
                                    <ComboBoxItem Content="中文" />
                                    <ComboBoxItem Content="英语" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="日期"
                                           Style="{StaticResource SectionBodyStyle}"
                                           Foreground="{StaticResource ModuleTextBrush}" />
                                <DatePicker x:Name="TargetDatePicker"
                                            Margin="0,8,0,0"
                                            SelectedDateChanged="TargetDatePicker_OnSelectedDateChanged" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,20,0,0"
                        Padding="20"
                        Background="{StaticResource ModuleCardAccentBackgroundBrush}"
                        BorderBrush="{StaticResource ModuleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="待听写词组"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock x:Name="ItemsSummaryTextBlock"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="共 0 组" />
                        </DockPanel>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="EditorItemsControl"
                                          AutomationProperties.AutomationId="DictationEditorItemsControl"
                                          AlternationCount="999">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="32"
                                                    Height="32"
                                                    VerticalAlignment="Center"
                                                    Background="White"
                                                    BorderBrush="{StaticResource ModuleBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ModuleAccentTextBrush}"
                                                           Text="{Binding DisplayIndex}" />
                                            </Border>

                                            <TextBox Grid.Column="1"
                                                     Height="38"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="EditorItemTextBox_OnTextChanged" />

                                            <Button Grid.Column="2"
                                                    MinWidth="72"
                                                    Margin="10,0,0,0"
                                                    Padding="12,8"
                                                    Click="RemoveItemButton_OnClick"
                                                    Content="移除"
                                                    Style="{StaticResource DangerButtonStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Left"
                                Padding="14,10"
                                Click="AddItemButton_OnClick"
                                Content="+ 添加词组"
                                AutomationProperties.AutomationId="DictationAddItemButton"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>
                </Border>

                <DockPanel Grid.Row="4"
                           Margin="0,22,0,0"
                           LastChildFill="False">
                    <TextBlock x:Name="FooterHintTextBlock"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource SectionBodyStyle}"
                               Text="编辑完成后先保存，再开始听写。" />

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button x:Name="ResetButton"
                                MinWidth="110"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="ResetButton_OnClick"
                                Content="重置"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="SaveButton"
                                MinWidth="124"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="SaveButton_OnClick"
                                Content="保存词组"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button x:Name="StartButton"
                                AutomationProperties.AutomationId="DictationStartSessionButton"
                                MinWidth="136"
                                Padding="16,10"
                                Click="StartButton_OnClick"
                                Content="开始听写"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
