<Window x:Class="DictationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudyGate 听写模块"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF7F2EA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="20"
                Background="White"
                CornerRadius="24">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="听写任务"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="语文、英语任务都在这里管理。"
                               Margin="0,6,0,16"
                               Foreground="#7A6A5A" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="CreateButton"
                                MinWidth="96"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="CreateButton_OnClick"
                                Content="新建任务" />
                        <Button x:Name="EditButton"
                                MinWidth="96"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="EditButton_OnClick"
                                Content="编辑任务" />
                        <Button x:Name="RefreshButton"
                                MinWidth="96"
                                Padding="16,10"
                                Click="RefreshButton_OnClick"
                                Content="刷新" />
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="TaskListBox"
                         Margin="0,16,0,0"
                         BorderThickness="0"
                         SelectionChanged="TaskListBox_OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="14"
                                    Background="#FFF7EFE4"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#7A6A5A"
                                               Text="{Binding Summary}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,20,20,20"
                Background="White"
                CornerRadius="24">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Text="请选择一个听写任务" />
                    <TextBlock x:Name="MetaTextBlock"
                               Margin="0,8,0,0"
                               FontSize="16"
                               Foreground="#7A6A5A"
                               Text="" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Padding="20"
                        Background="#FFF8F4EE"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="任务说明"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="DescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   Foreground="#66584B"
                                   TextWrapping="Wrap"
                                   Text="创建任务后，进入执行页逐项播放，默认隐藏答案。" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,24,0,0"
                        Padding="20"
                        Background="#FFF4F8FB"
                        CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="词组预览"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <ListBox x:Name="PreviewListBox"
                                 Grid.Row="1"
                                 Margin="0,12,0,0"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="White"
                                            CornerRadius="12">
                                        <TextBlock Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3"
                            Margin="0,24,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="StartButton"
                            MinWidth="132"
                            Margin="0,0,12,0"
                            Padding="18,12"
                            Click="StartButton_OnClick"
                            Content="开始听写" />
                    <Button x:Name="CloseButton"
                            MinWidth="120"
                            Padding="18,12"
                            Click="CloseButton_OnClick"
                            Content="关闭" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
