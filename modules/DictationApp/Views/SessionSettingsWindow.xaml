<Window x:Class="DictationApp.Views.SessionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="听写设置"
        Width="420"
        Height="280"
        MinWidth="420"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource ModuleShellBackgroundBrush}">
        <Border Margin="20"
                Padding="22"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="听写设置"
                           FontSize="26"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1"
                           Margin="0,10,0,0"
                           Style="{StaticResource SectionBodyStyle}"
                           Text="这些设置只决定每题播放次数和等待书写的秒数。" />

                <Grid Grid.Row="2"
                      Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="每题播放几遍"
                                   Style="{StaticResource SectionBodyStyle}"
                                   Foreground="{StaticResource ModuleTextBrush}" />
                        <ComboBox x:Name="RepeatCountComboBox"
                                  Margin="0,8,12,0"
                                  Height="34" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="每题等待几秒"
                                   Style="{StaticResource SectionBodyStyle}"
                                   Foreground="{StaticResource ModuleTextBrush}" />
                        <ComboBox x:Name="WriteSecondsComboBox"
                                  Margin="0,8,0,0"
                                  Height="34" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="3"
                           Margin="0,20,0,0"
                           Style="{StaticResource SectionBodyStyle}"
                           Text="进入听写后会自动按设置推进：播放当前题，等待书写，自动收进上方展示区，再进入下一题。" />

                <StackPanel Grid.Row="4"
                            Margin="0,20,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="96"
                            Margin="0,0,10,0"
                            Padding="14,10"
                            Click="CancelButton_OnClick"
                            Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button MinWidth="110"
                            Padding="14,10"
                            Click="SaveButton_OnClick"
                            Content="保存设置"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
