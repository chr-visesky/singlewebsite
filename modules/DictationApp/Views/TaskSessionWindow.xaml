<Window x:Class="DictationApp.Views.TaskSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="执行听写任务"
        Icon="pack://application:,,,/Assets/module-icon.ico"
        Width="860"
        Height="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeaderTextBlock"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Text="听写执行中" />
            <TextBlock x:Name="ProgressTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#7A6A5A"
                       Text="第 1 项 / 共 1 项" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Padding="28"
                Background="#FFF8F4EE"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="先播放，再自己写，最后核对答案"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="InstructionTextBlock"
                           Grid.Row="1"
                           Margin="0,16,0,0"
                           Foreground="#7A6A5A"
                           Text="答案默认隐藏，避免直接照抄。" />
                <TextBox x:Name="AttemptTextBox"
                         Grid.Row="2"
                         Margin="0,18,0,0"
                         MinHeight="110"
                         Padding="16"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         TextChanged="AttemptTextBox_OnTextChanged" />
                <TextBlock x:Name="ResultTextBlock"
                           Grid.Row="3"
                           Margin="0,18,0,0"
                           Foreground="#66584B"
                           TextWrapping="Wrap" />
                <Border Grid.Row="4"
                        Margin="0,18,0,0"
                        Padding="20"
                        Background="White"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="标准答案"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="AnswerTextBlock"
                                   Margin="0,18,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Text="先完成作答，再核对答案"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,24,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="PlayButton"
                    MinWidth="120"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="PlayButton_OnClick"
                    Content="播放本项" />
            <Button x:Name="CheckButton"
                    MinWidth="136"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="CheckButton_OnClick"
                    Content="核对答案" />
            <Button x:Name="RevealButton"
                    MinWidth="146"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="RevealButton_OnClick"
                    Content="跳过并看答案" />
            <Button x:Name="NextButton"
                    MinWidth="120"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="NextButton_OnClick"
                    Content="下一项" />
            <Button MinWidth="120"
                    Padding="16,12"
                    Click="FinishButton_OnClick"
                    Content="结束" />
        </StackPanel>
    </Grid>
</Window>
