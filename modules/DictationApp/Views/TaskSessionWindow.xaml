<Window x:Class="DictationApp.Views.TaskSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="本课听写"
        AutomationProperties.AutomationId="DictationLessonSessionWindow"
        Icon="pack://application:,,,/Assets/module-icon.ico"
        Width="1160"
        Height="780"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Loaded="Window_OnLoaded"
        Closed="Window_OnClosed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource ModuleShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="156" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,0"
                Padding="12"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Focusable="False"
                              CanContentScroll="False">
                    <ItemsControl x:Name="LessonItemsControl"
                                  AutomationProperties.AutomationId="DictationLessonItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder"
                                        Width="104"
                                        Height="60"
                                        Margin="0,0,8,0"
                                        Padding="8,6"
                                        Background="{StaticResource ModuleCardBackgroundBrush}"
                                        BorderBrush="{StaticResource ModuleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        AutomationProperties.AutomationId="{Binding CardAutomationId}"
                                        AutomationProperties.Name="{Binding CardAutomationName}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border x:Name="NumberBadge"
                                                HorizontalAlignment="Left"
                                                Padding="7,1"
                                                Background="#FFF1E7D8"
                                                CornerRadius="7">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ModuleMutedTextBrush}"
                                                       Text="{Binding ItemNumberLabel}" />
                                        </Border>

                                        <Border Grid.Row="1"
                                                Margin="0,5,0,0"
                                                Background="White"
                                                BorderBrush="{StaticResource ModuleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="9">
                                            <Image Source="{Binding SavedPreviewImage}"
                                                   Stretch="Uniform"
                                                   Margin="3"
                                                   Visibility="{Binding HasSavedPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Border>

                                        <Grid Height="1"
                                              Grid.RowSpan="2"
                                              VerticalAlignment="Bottom"
                                              Opacity="0.01"
                                              IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock AutomationProperties.AutomationId="{Binding StatusAutomationId}"
                                                       FontSize="1"
                                                       Foreground="Transparent"
                                                       Text="{Binding StatusText}" />
                                            <TextBlock Grid.Column="1"
                                                       AutomationProperties.AutomationId="{Binding RecognitionAutomationId}"
                                                       FontSize="1"
                                                       Foreground="Transparent"
                                                       Text="{Binding RecognizedText}" />
                                            <TextBlock Grid.Column="2"
                                                       AutomationProperties.AutomationId="{Binding AnswerAutomationId}"
                                                       FontSize="1"
                                                       Foreground="Transparent"
                                                       Text="{Binding AnswerText}" />
                                            <TextBlock Grid.Column="3"
                                                       AutomationProperties.AutomationId="{Binding SavedDisplayAutomationId}"
                                                       FontSize="1"
                                                       Foreground="Transparent"
                                                       Text="{Binding SavedDisplayText}" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentItem}" Value="True">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource ModuleAccentBrush}" />
                                        <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                                        <Setter TargetName="NumberBadge" Property="Background" Value="{StaticResource ModuleAccentSoftBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLevel}" Value="Captured">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFE3C6A6" />
                                        <Setter TargetName="NumberBadge" Property="Background" Value="#FFF3E2C7" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLevel}" Value="Correct">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FF8BC495" />
                                        <Setter TargetName="NumberBadge" Property="Background" Value="#FFDDEDDD" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLevel}" Value="Retry">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFE0BF5D" />
                                        <Setter TargetName="NumberBadge" Property="Background" Value="#FFF8E6A8" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLevel}" Value="Wrong">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFD68C73" />
                                        <Setter TargetName="NumberBadge" Property="Background" Value="#FFF7D5CB" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Height="1"
                      VerticalAlignment="Top"
                      Opacity="0.01"
                      IsHitTestVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressTextBlock"
                               AutomationProperties.AutomationId="DictationLessonProgressText"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="本课共 0 题" />
                    <TextBlock x:Name="ModeTextBlock"
                               AutomationProperties.AutomationId="DictationLessonModeText"
                               Grid.Column="1"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="整课听写" />
                    <TextBlock x:Name="SummaryTextBlock"
                               AutomationProperties.AutomationId="DictationLessonSummaryText"
                               Grid.Column="2"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="等待开始" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20,14,20,20"
                Padding="14"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <InkCanvas x:Name="AnswerInkCanvas"
                           AutomationProperties.AutomationId="DictationLessonInkCanvas"
                           Background="#FFFFFCF8"
                           Loaded="AnswerInkCanvas_OnLoaded"
                           Unloaded="AnswerInkCanvas_OnUnloaded" />

                <Button x:Name="ClearWritingButton"
                        AutomationProperties.AutomationId="DictationClearWritingButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,6,6,0"
                        Padding="14,8"
                        Click="ClearWritingButton_OnClick"
                        Content="清空手写"
                        Style="{StaticResource SecondaryButtonStyle}" />

                <Grid Height="1"
                      VerticalAlignment="Bottom"
                      Opacity="0.01"
                      IsHitTestVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="InstructionTextBlock"
                               AutomationProperties.AutomationId="DictationLessonInstructionText"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="等待开始" />
                    <TextBlock x:Name="FooterTextBlock"
                               AutomationProperties.AutomationId="DictationLessonFooterText"
                               Grid.Column="1"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="等待开始" />
                    <TextBlock x:Name="CurrentQuestionTextBlock"
                               AutomationProperties.AutomationId="DictationCurrentItemText"
                               Grid.Column="2"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="当前题目：准备开始" />
                    <TextBlock x:Name="CurrentStatusTextBlock"
                               AutomationProperties.AutomationId="DictationCurrentStatusText"
                               Grid.Column="3"
                               FontSize="1"
                               Foreground="Transparent"
                               Text="等待开始" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
