<Window x:Class="DictationApp.Views.TaskSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="执行听写任务"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeaderTextBlock"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Text="听写执行中" />
            <TextBlock x:Name="ProgressTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#7A6A5A"
                       Text="第 1 项 / 共 1 项" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Padding="28"
                Background="#FFF8F4EE"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="当前答案"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="AnswerTextBlock"
                           Grid.Row="1"
                           Margin="0,24,0,0"
                           FontSize="38"
                           FontWeight="SemiBold"
                           Text="******"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,24,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button MinWidth="130"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="PlayButton_OnClick"
                    Content="播放本项" />
            <Button x:Name="RevealButton"
                    MinWidth="130"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="RevealButton_OnClick"
                    Content="查看答案" />
            <Button x:Name="NextButton"
                    MinWidth="130"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="NextButton_OnClick"
                    Content="下一项" />
            <Button MinWidth="120"
                    Padding="16,12"
                    Click="FinishButton_OnClick"
                    Content="结束" />
        </StackPanel>
    </Grid>
</Window>
