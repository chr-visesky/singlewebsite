<Window x:Class="RecitationApp.Views.TaskSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="执行背诵任务"
        Icon="pack://application:,,,/Assets/module-icon.ico"
        Width="980"
        Height="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeaderTextBlock"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Text="背诵执行中" />
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#7A6A5A"
                       Text="点击“开始录音”后开始背诵。" />
        </StackPanel>

        <CheckBox x:Name="HideSourceCheckBox"
                  Grid.Row="1"
                  Margin="0,18,0,0"
                  Checked="HideSourceCheckBox_OnChanged"
                  Unchecked="HideSourceCheckBox_OnChanged"
                  Content="隐藏原文" />

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="原文">
                <TextBox x:Name="SourceTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True" />
            </GroupBox>
            <GroupBox Grid.Column="1"
                      Margin="18,0,0,0"
                      Header="转写结果">
                <TextBox x:Name="TranscriptTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True" />
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="3"
                  Margin="0,18,0,0"
                  Header="差异摘要">
            <TextBox x:Name="DiffTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True" />
        </GroupBox>

        <StackPanel Grid.Row="4"
                    Margin="0,24,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="StartRecordingButton"
                    MinWidth="132"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="StartRecordingButton_OnClick"
                    Content="开始录音" />
            <Button x:Name="StopRecordingButton"
                    MinWidth="132"
                    Margin="0,0,12,0"
                    Padding="16,12"
                    Click="StopRecordingButton_OnClick"
                    Content="停止并转写" />
            <Button MinWidth="120"
                    Padding="16,12"
                    Click="FinishButton_OnClick"
                    Content="关闭" />
        </StackPanel>
    </Grid>
</Window>
