<Window x:Class="RecitationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudyGate 背诵模块"
        Icon="pack://application:,,,/Assets/module-icon.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF6F1E8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="20"
                Background="White"
                CornerRadius="24">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="背诵任务"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="语文背诵任务、原文和比对结果都在这里。"
                               Margin="0,6,0,16"
                               Foreground="#7A6A5A" />
                    <StackPanel Orientation="Horizontal">
                        <Button MinWidth="96"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="CreateButton_OnClick"
                                Content="新建任务" />
                        <Button x:Name="EditButton"
                                MinWidth="96"
                                Margin="0,0,12,0"
                                Padding="16,10"
                                Click="EditButton_OnClick"
                                Content="编辑任务" />
                        <Button MinWidth="96"
                                Padding="16,10"
                                Click="RefreshButton_OnClick"
                                Content="刷新" />
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="TaskListBox"
                         Margin="0,16,0,0"
                         BorderThickness="0"
                         SelectionChanged="TaskListBox_OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="14"
                                    Background="#FFF8F3EA"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#7A6A5A"
                                               Text="{Binding Summary}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,20,20,20"
                Background="White"
                CornerRadius="24">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Text="请选择一个背诵任务" />
                    <TextBlock x:Name="MetaTextBlock"
                               Margin="0,8,0,0"
                               FontSize="16"
                               Foreground="#7A6A5A" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="原文预览"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="SourceTextBox"
                             Grid.Row="1"
                             Margin="0,12,0,0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True" />

                    <TextBlock Grid.Row="2"
                               Margin="0,20,0,0"
                               Text="最近一次结果"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="LatestResultTextBox"
                             Grid.Row="3"
                             Margin="0,12,0,0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True" />
                </Grid>

                <StackPanel Grid.Row="2"
                            Margin="0,24,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="StartButton"
                            MinWidth="132"
                            Margin="0,0,12,0"
                            Padding="18,12"
                            Click="StartButton_OnClick"
                            Content="开始背诵" />
                    <Button MinWidth="120"
                            Padding="18,12"
                            Click="CloseButton_OnClick"
                            Content="关闭" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
