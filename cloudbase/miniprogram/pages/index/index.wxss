.grow {
  min-width: 0;
  flex: 1 1 auto;
}

.masthead {
  padding: 28rpx 30rpx;
  min-width: 0;
}

.masthead__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
  flex-wrap: nowrap;
}

.masthead__title {
  margin-top: 0;
  font-size: 46rpx;
  flex: 1 1 auto;
  min-width: 0;
  white-space: nowrap;
}

.status-pill {
  margin-top: 12rpx;
  max-width: 100%;
  min-width: 0;
}

.masthead__actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
}

.header-chip,
.header-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 0;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 39, 45, 0.08);
  color: #394851;
  text-align: center;
  flex: 0 0 auto;
  box-sizing: border-box;
}

.header-chip {
  font-size: 22rpx;
  line-height: 1;
}

.header-icon {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  font-size: 28rpx;
  line-height: 1;
}

.header-chip--active {
  background: rgba(31, 39, 45, 0.14);
}

.calendar-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.calendar-toolbar__title {
  font-size: 30rpx;
  font-weight: 700;
  flex: 1 1 auto;
  min-width: 0;
  text-align: center;
}

.calendar-nav {
  width: 68rpx;
  min-width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(248, 242, 232, 0.1);
  color: #f8f2e8;
  text-align: center;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 20rpx;
  min-width: 0;
}

.calendar-weekdays__item {
  text-align: center;
  color: rgba(248, 242, 232, 0.72);
  font-size: 22rpx;
  min-width: 0;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 12rpx;
  min-width: 0;
}

.calendar-cell {
  min-width: 0;
  min-height: 118rpx;
  padding: 10rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid transparent;
  box-sizing: border-box;
}

.calendar-cell--muted {
  opacity: 0.38;
}

.calendar-cell--today {
  border-color: rgba(255, 211, 124, 0.46);
}

.calendar-cell--selected {
  background: rgba(255, 211, 124, 0.18);
  border-color: rgba(255, 211, 124, 0.56);
}

.calendar-cell__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-width: 0;
}

.calendar-cell__day {
  font-size: 22rpx;
  font-weight: 700;
  color: #f8f2e8;
  min-width: 0;
}

.calendar-cell__count {
  font-size: 20rpx;
  color: #ffd37c;
  text-align: right;
  flex: 0 0 auto;
}

.calendar-cell__preview {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.3;
  color: rgba(248, 242, 232, 0.86);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calendar-cell__preview--soft {
  color: rgba(248, 242, 232, 0.6);
}

.plan-empty {
  margin-top: 18rpx;
}

.selected-list {
  margin-top: 18rpx;
  min-width: 0;
}

.selected-card {
  padding: 18rpx 20rpx;
}

.selected-card--skipped {
  opacity: 0.72;
  background: linear-gradient(180deg, rgba(242, 238, 232, 0.96), rgba(235, 231, 225, 0.96));
}

.badge--muted {
  background: rgba(31, 39, 45, 0.05);
  color: #7b868d;
}

.badge--parent {
  background: rgba(202, 109, 51, 0.12);
  color: #bc5a2a;
}

.badge--student {
  background: rgba(57, 111, 111, 0.14);
  color: #326868;
}

.selected-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
}

.selected-row__main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1 1 auto;
}

.selected-row__content {
  min-width: 0;
  flex: 1 1 auto;
  display: grid;
  gap: 4rpx;
}

.selected-row__title-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  flex-wrap: nowrap;
}

.selected-row__title {
  min-width: 0;
  flex: 0 1 auto;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f272d;
}

.selected-row__meta {
  color: #67757f;
  font-size: 20rpx;
  line-height: 1.2;
}

.selected-badge {
  padding: 6rpx 12rpx;
  font-size: 18rpx;
  flex: 0 0 auto;
}

.selected-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 0;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  margin: 0;
  flex: 0 0 auto;
  white-space: nowrap;
  box-sizing: border-box;
}

.selected-action--danger {
  background: rgba(191, 61, 49, 0.12);
  color: #af352b;
}

.selected-action--skip {
  background: rgba(202, 109, 51, 0.12);
  color: #bc5a2a;
}

.selected-action--restore {
  background: rgba(57, 111, 111, 0.14);
  color: #326868;
}

.split--compact {
  align-items: end;
  min-width: 0;
}

.picker-input {
  width: 100%;
  height: 80rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1px solid rgba(31, 39, 45, 0.12);
  background: rgba(255, 252, 247, 0.98);
  color: #1f272d;
  font-size: 24rpx;
  line-height: 80rpx;
}

.target-grid {
  display: grid;
  gap: 14rpx;
  min-width: 0;
}

.target-grid checkbox-group {
  display: block;
  min-width: 0;
}

.target-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  border: 1px solid rgba(31, 39, 45, 0.08);
  background: rgba(31, 39, 45, 0.04);
  color: #4e5d67;
  font-size: 24rpx;
  font-weight: 700;
}

.target-chip--active {
  background: rgba(202, 109, 51, 0.12);
  border-color: rgba(202, 109, 51, 0.26);
  color: #bc5a2a;
}

.weekday-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  min-width: 0;
}

.weekday-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 72rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  border: 1px solid rgba(31, 39, 45, 0.08);
  background: rgba(255, 252, 247, 0.95);
  color: #46545e;
  font-size: 24rpx;
  box-sizing: border-box;
}

.weekday-chip--active {
  background: rgba(202, 109, 51, 0.12);
  border-color: rgba(202, 109, 51, 0.26);
  color: #bc5a2a;
}

.weekday-chip checkbox {
  transform: scale(0.82);
}

.weekly-card {
  padding: 22rpx;
  min-width: 0;
}

.weekly-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
}

.weekly-row__main {
  min-width: 0;
  flex: 1 1 auto;
}

.weekly-row__title-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.weekly-row__title-line .list-card__title {
  min-width: 0;
  flex: 0 1 auto;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.weekly-delete {
  align-self: center;
  width: auto;
  min-width: 0;
  min-height: 64rpx;
  line-height: 64rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(191, 61, 49, 0.12);
  color: #af352b;
  font-size: 24rpx;
  flex: 0 0 auto;
  box-sizing: border-box;
}

@media (max-width: 520px) {
  .masthead__top {
    gap: 12rpx;
  }

  .masthead__title {
    font-size: 42rpx;
  }

  .status-pill {
    font-size: 22rpx;
    line-height: 1.3;
  }

  .calendar-weekdays,
  .calendar-grid {
    gap: 6rpx;
  }

  .calendar-cell {
    min-height: 104rpx;
    padding: 8rpx 6rpx;
    border-radius: 16rpx;
  }

  .calendar-cell__day {
    font-size: 20rpx;
  }

  .calendar-cell__count {
    font-size: 18rpx;
  }

  .calendar-cell__preview {
    margin-top: 4rpx;
    font-size: 16rpx;
    line-height: 1.25;
  }

  .selected-row {
    gap: 12rpx;
  }

  .selected-row__main {
    gap: 8rpx;
  }

  .selected-row__title-line,
  .weekly-row__title-line {
    gap: 6rpx;
  }

  .selected-badge {
    padding: 4rpx 10rpx;
    font-size: 16rpx;
  }

  .selected-action {
    height: 38rpx;
    line-height: 38rpx;
    font-size: 16rpx;
    padding: 0 8rpx;
  }

  .weekly-delete {
    min-height: 56rpx;
    line-height: 56rpx;
    font-size: 22rpx;
    padding: 0 14rpx;
  }
}

@media (max-width: 420px) {
  .split--compact {
    grid-template-columns: minmax(0, 1fr);
  }

  .weekday-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .masthead__actions {
    gap: 10rpx;
  }

  .header-chip {
    padding: 0 16rpx;
    font-size: 20rpx;
  }

  .header-icon {
    width: 56rpx;
    height: 56rpx;
    font-size: 26rpx;
  }

  .calendar-toolbar__title {
    font-size: 28rpx;
  }
}
