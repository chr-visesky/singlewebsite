<view class="shell">
  <view class="masthead">
    <view class="masthead__eyebrow">SYSTEM</view>
    <view class="masthead__title">系统管理</view>
    <view class="status-pill">{{identityHint}}</view>
  </view>

  <view class="panel panel--ink">
    <view class="panel__title">当前身份</view>
    <view class="meta meta--light">OPENID</view>
    <view class="meta meta--light meta--break">{{openIdDisplay}}</view>
    <view class="action-row">
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="refreshIdentity">刷新身份</view>
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="copyOpenId">复制 OPENID</view>
    </view>
  </view>

  <view wx:if="{{authorized}}" class="panel">
    <view class="panel__title">设置</view>
    <view class="action-row action-row--start">
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="openClassroomsPage">在线课堂模块</view>
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="openLibrariesPage">百度网盘视频模块</view>
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="openToolsPage">学习工具模块</view>
    </view>
  </view>

  <view wx:if="{{authorized}}" class="panel">
    <view class="panel__title">退出密码</view>
    <view class="panel__subtitle">{{hasExitPassword ? exitPasswordUpdatedAtDisplay : '未设置'}}</view>

    <view class="field">
      <view class="field__label">新密码</view>
      <input
        class="input"
        password="{{true}}"
        placeholder="至少 4 位"
        value="{{exitPasswordDraft}}"
        bindinput="onExitPasswordInput"
      />
    </view>

    <view class="field">
      <view class="field__label">确认密码</view>
      <input
        class="input"
        password="{{true}}"
        placeholder="再输一次"
        value="{{exitPasswordConfirmDraft}}"
        bindinput="onExitPasswordConfirmInput"
      />
    </view>

    <view class="action-row">
      <view class="tap-button tap-button--primary" hover-class="tap-button--active" bindtap="saveExitPassword">保存密码</view>
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="reloadControlSettings">刷新</view>
      <view wx:if="{{hasExitPassword}}" class="tap-button tap-button--danger" hover-class="tap-button--active" bindtap="clearExitPassword">清空</view>
    </view>
  </view>

  <view wx:if="{{authorized}}" class="panel">
    <view class="panel__title">桌面客户端授权</view>
    <view class="panel__subtitle">{{studentDevicesUpdatedAtDisplay}}</view>

    <view class="action-row">
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="reloadStudentDevices">刷新列表</view>
    </view>

    <view wx:if="{{!hasStudentDevices}}" class="empty-state">
      <view class="empty-state__title">还没有客户端申请</view>
      <view class="meta">桌面端打开学生计划后会自动发起申请，你在这里批准或删除即可。</view>
    </view>

    <view wx:if="{{hasStudentDevices}}" class="list-stack">
      <view wx:for="{{studentDevices}}" wx:key="id" class="list-card">
        <view class="list-card__head">
          <view class="grow">
            <view class="list-card__title">{{item.label}}</view>
            <view class="meta meta--break">{{item.id}}</view>
            <view class="meta">{{item.status === 'approved' ? '批准时间：' + item.approvedAtDisplay : '申请时间：' + item.requestedAtDisplay}}</view>
          </view>
          <view class="badge">{{item.statusLabel}}</view>
        </view>

        <view class="action-row">
          <view
            wx:if="{{item.status === 'pending'}}"
            class="tap-button tap-button--primary"
            hover-class="tap-button--active"
            data-deviceid="{{item.id}}"
            bindtap="approveStudentDevice"
          >批准</view>
          <view
            class="tap-button tap-button--danger"
            hover-class="tap-button--active"
            data-deviceid="{{item.id}}"
            data-label="{{item.label}}"
            bindtap="removeStudentDevice"
          >删除</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{authorized}}" class="panel">
    <view class="panel__title">管理员列表</view>
    <view class="panel__subtitle">{{adminUpdatedAtDisplay}}</view>

    <view class="field">
      <view class="field__label">添加管理员 OPENID</view>
      <input class="input" placeholder="把你老婆手机里显示的 OPENID 粘进来" value="{{adminDraftOpenId}}" bindinput="onAdminInput" />
    </view>

    <view class="action-row">
      <view class="tap-button tap-button--primary" hover-class="tap-button--active" bindtap="addAdmin">添加管理员</view>
      <view class="tap-button tap-button--secondary" hover-class="tap-button--active" bindtap="reloadAdmins">刷新列表</view>
    </view>

    <view wx:if="{{!hasAdmins}}" class="empty-state">
      <view class="empty-state__title">还没有管理员记录</view>
      <view class="meta">第一次会先沿用云函数环境变量里的管理员名单。</view>
    </view>

    <view wx:if="{{hasAdmins}}" class="list-stack">
      <view wx:for="{{admins}}" wx:key="openId" class="list-card">
        <view class="list-card__head">
          <view class="grow">
            <view class="list-card__title">{{item.isSelf ? '当前管理员（你）' : '管理员'}}</view>
            <view class="meta meta--break">{{item.openId}}</view>
          </view>
          <view class="badge">{{item.isSelf ? '本人' : '已授权'}}</view>
        </view>

        <view class="action-row">
          <view class="tap-button tap-button--danger" hover-class="tap-button--active" data-openid="{{item.openId}}" bindtap="removeAdmin">移除</view>
        </view>
      </view>
    </view>
  </view>
</view>
